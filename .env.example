# Django settings
SECRET_KEY=your-super-secret-key-change-this-in-production-min-50-chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com

# Security
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000

# Database (PostgreSQL)
POSTGRES_DB=pair_canvas
POSTGRES_USER=pair_canvas
POSTGRES_PASSWORD=change-this-password-in-production
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/1

# Email (for password reset, notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Pair Canvas <noreply@yourdomain.com>

# Admin notifications
ADMIN_NAMES=Admin|Support
ADMIN_EMAILS=admin@yourdomain.com|support@yourdomain.com

# Logging
LOG_FILE=/var/log/pair_canvas/django.log
DJANGO_LOG_LEVEL=INFO

# CORS (if needed)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate limiting
WEBSOCKET_RATE_LIMIT=100/minute
